# ──────────────────────────────────────────────
# Barrage-Flow Manager — Backend Environment
# Copy to .env and fill in real values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────

# App
DEBUG=true

# Database (PostgreSQL)
DATABASE_URL=postgresql://bfm_user:bfm_pass@db:5432/barrage_flow

# Redis
REDIS_URL=redis://redis:6379/0

# Security — CHANGE THIS IN PRODUCTION
SECRET_KEY=dev-secret-key-change-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# MFA
MFA_ISSUER=BarrageFlowManager

# CORS — comma-separated origins
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Business Rules (overrides code defaults)
DEFAULT_SAFETY_RESERVE_PCT=25.0
DEFAULT_WARNING_ZONE_PCT=40.0
DEFAULT_ALERT_ZONE_PCT=60.0

# Email alerts (optional for dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_RECIPIENTS=[]
